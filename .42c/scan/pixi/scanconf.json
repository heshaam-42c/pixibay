{
  "version": "2.0.0",
  "runtimeConfiguration": {
    "environment": "default",
    "laxTestingModeEnabled": false,
    "apiConnectivityCheck": true,
    "logLevel": "error",
    "logDestination": "stdout+platform",
    "logMaxFileSize": 2147483648,
    "requestHeaderNameRequestId": "x-scan-request-id",
    "requestHeaderNameScenarioId": "x-scan-scenario-id",
    "requestHeaderNameRequestType": "x-scan-request-type",
    "requestFlowrate": 100,
    "requestTimeout": 30,
    "requestTlsInsecureSkipVerify": true,
    "responseFollowRedirection": false,
    "responseMaxBodySizeScan": 10485760,
    "happyPathOnly": false,
    "maxRequestRetryAttempts": 5,
    "maxScanDuration": 1800,
    "memoryLimit": 2147483648,
    "memoryTimeSpan": 10,
    "reportMaxRequestSizeHappyPath": 8092,
    "reportMaxRequestSizeTest": 8092,
    "reportIncludeRequestBody": true,
    "reportIncludeResponseBody": true,
    "reportMaxHttpResponseSizeHappyPath": 8092,
    "reportMaxBodySizeHappyPath": 8092,
    "reportMaxHttpResponseSizeTest": 8092,
    "reportMaxBodySizeTest": 8092,
    "reportIssuesOnly": false,
    "reportMaxIssues": 1000,
    "reportMaxSize": 20971520,
    "reportGenerateCurlCommand": true,
    "normalizeServerUrls": true
  },
  "customizations": {
    "happyPaths": {
      "retry": 1,
      "responsePolicy": {
        "httpStatusExpected": true,
        "mustBeConformant": true
      },
      "httpStatusExpected": [
        "2XX",
        "404"
      ]
    },
    "tests": {
      "skippedKeys": [
        "schema-maxlength-scan"
      ],
      "responsePolicy": {
        "httpStatusExpected": true,
        "mustBeConformant": true
      }
    },
    "requests": {}
  },
  "authenticationDetails": [
    {
      "access-token": {
        "type": "apiKey",
        "in": "header",
        "name": "x-access-token",
        "default": "User1Token",
        "credentials": {
          "User1Token": {
            "description": "User 1 token via /user/login",
            "credential": "{{access-token}}",
            "requests": [
              {
                "$ref": "#/operations/authenticate/request",
                "responses": {
                  "200": {
                    "expectations": {
                      "httpStatus": 200
                    },
                    "variableAssignments": {
                      "access-token": {
                        "in": "body",
                        "from": "response",
                        "contentType": "json",
                        "path": {
                          "type": "jsonPointer",
                          "value": "/token"
                        }
                      }
                    }
                  }
                }
              }
            ]
          },
          "User2Token": {
            "description": "User 2 token via /user/login",
            "credential": "{{user2AccessToken}}",
            "requests": [
              {
                "$ref": "#/operations/authenticate/request",
                "environment": {
                  "username": "{{user2Username}}",
                  "password": "{{user2Password}}"
                },
                "responses": {
                  "200": {
                    "expectations": {
                      "httpStatus": 200
                    },
                    "variableAssignments": {
                      "user2AccessToken": {
                        "in": "body",
                        "from": "response",
                        "contentType": "json",
                        "path": {
                          "type": "jsonPointer",
                          "value": "/token"
                        }
                      }
                    }
                  }
                }
              }
            ]
          },
          "AdminToken": {
            "description": "Admin token via /user/login",
            "credential": "{{adminAccessToken}}",
            "requests": [
              {
                "$ref": "#/operations/authenticate/request",
                "environment": {
                  "username": "{{adminUsername}}",
                  "password": "{{adminPassword}}"
                },
                "responses": {
                  "200": {
                    "expectations": {
                      "httpStatus": 200
                    },
                    "variableAssignments": {
                      "adminAccessToken": {
                        "in": "body",
                        "from": "response",
                        "contentType": "json",
                        "path": {
                          "type": "jsonPointer",
                          "value": "/token"
                        }
                      }
                    }
                  }
                }
              }
            ]
          }
        }
      }
    }
  ],
